<?xml version="1.0"?>
<!--
  Minimal, self-contained URDF for Jessica.
  - 4-wheel differential drive base
  - pan-tilt mechanism carrying Jessica's head
  - inline ros2_control block driving the ESP32 hardware interface

  This is intentionally lean (no lidar/camera/gazebo/inertial clutter). It exists
  so robot_state_publisher has a valid tree and the controller_manager can load
  the ESP32 hardware. Re-tune the dimensions/limits to match the real robot.
-->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="jessica">

  <xacro:arg name="use_ros2_control" default="true"/>
  <xacro:arg name="sim_mode"          default="false"/>

  <!-- ===================== Geometry knobs ===================== -->
  <!-- Wheels are a bit closer together than the old robot; re-tune as needed. -->
  <xacro:property name="wheel_radius"   value="0.072"/>
  <xacro:property name="wheel_width"    value="0.04"/>
  <xacro:property name="wheel_sep_y"    value="0.13"/>   <!-- half track (centre→wheel) -->
  <xacro:property name="wheel_sep_x"    value="0.10"/>   <!-- half wheelbase -->
  <xacro:property name="chassis_length" value="0.30"/>
  <xacro:property name="chassis_width"  value="0.22"/>
  <xacro:property name="chassis_height" value="0.10"/>

  <!-- ===================== Materials ===================== -->
  <material name="gray">  <color rgba="0.75 0.75 0.75 1"/></material>
  <material name="blue">  <color rgba="0.2 0.2 1 1"/></material>
  <material name="black"> <color rgba="0.05 0.05 0.05 1"/></material>
  <material name="pink">  <color rgba="1.0 0.4 0.7 1"/></material>

  <!-- ===================== Base ===================== -->
  <link name="base_link"/>

  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="base_footprint"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>
  <link name="base_footprint"/>

  <joint name="chassis_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="chassis"/>
    <origin xyz="0 0 ${wheel_radius}" rpy="0 0 0"/>
  </joint>
  <link name="chassis">
    <visual>
      <origin xyz="0 0 ${chassis_height/2}" rpy="0 0 0"/>
      <geometry><box size="${chassis_length} ${chassis_width} ${chassis_height}"/></geometry>
      <material name="gray"/>
    </visual>
  </link>

  <!-- ===================== Wheels ===================== -->
  <xacro:macro name="wheel" params="name x y reflect">
    <link name="${name}">
      <visual>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <geometry><cylinder length="${wheel_width}" radius="${wheel_radius}"/></geometry>
        <material name="black"/>
      </visual>
    </link>
    <joint name="${name}_joint" type="continuous">
      <parent link="base_link"/>
      <child  link="${name}"/>
      <origin xyz="${x} ${y} ${wheel_radius}" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
    </joint>
  </xacro:macro>

  <xacro:wheel name="left_front_wheel"  x="${ wheel_sep_x}" y="${ wheel_sep_y}" reflect="1"/>
  <xacro:wheel name="left_rear_wheel"   x="${-wheel_sep_x}" y="${ wheel_sep_y}" reflect="1"/>
  <xacro:wheel name="right_front_wheel" x="${ wheel_sep_x}" y="${-wheel_sep_y}" reflect="-1"/>
  <xacro:wheel name="right_rear_wheel"  x="${-wheel_sep_x}" y="${-wheel_sep_y}" reflect="-1"/>

  <!-- ===================== Pan-tilt head ===================== -->
  <!-- Mounted higher than the old robot; raise mast_height to taste. -->
  <xacro:property name="mast_height" value="0.35"/>

  <joint name="mast_joint" type="fixed">
    <parent link="chassis"/>
    <child  link="mast"/>
    <origin xyz="0 0 ${chassis_height}" rpy="0 0 0"/>
  </joint>
  <link name="mast">
    <visual>
      <origin xyz="0 0 ${mast_height/2}" rpy="0 0 0"/>
      <geometry><box size="0.04 0.04 ${mast_height}"/></geometry>
      <material name="gray"/>
    </visual>
  </link>

  <!-- pan: yaw about Z -->
  <joint name="pan_joint" type="revolute">
    <parent link="mast"/>
    <child  link="pan_link"/>
    <origin xyz="0 0 ${mast_height}" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.57" upper="1.57" effort="5.0" velocity="3.0"/>
  </joint>
  <link name="pan_link">
    <visual>
      <origin xyz="0 0 0.02" rpy="0 0 0"/>
      <geometry><box size="0.06 0.06 0.04"/></geometry>
      <material name="gray"/>
    </visual>
  </link>

  <!-- tilt: pitch about Y -->
  <joint name="tilt_joint" type="revolute">
    <parent link="pan_link"/>
    <child  link="head"/>
    <origin xyz="0 0 0.05" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.5" upper="0.87" effort="5.0" velocity="3.0"/>
  </joint>
  <link name="head">
    <visual>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <geometry><box size="0.12 0.12 0.12"/></geometry>
      <material name="pink"/>
    </visual>
  </link>

  <!-- ===================== ros2_control ===================== -->
  <xacro:if value="$(arg use_ros2_control)">
    <ros2_control name="JessicaESP32" type="system">
      <hardware>
        <plugin>esp32_combined_hardware/ESP32CombinedHardware</plugin>
        <param name="device">/dev/esp32_motor</param>
        <param name="baud_rate">115200</param>
        <param name="timeout_ms">1000</param>
        <param name="wheel_radius">7.2</param>        <!-- cm, used by hardware protocol -->
        <param name="enc_counts_per_rev">1425</param>
      </hardware>

      <!-- Wheels: velocity command, position+velocity state (order matters: 0-3) -->
      <joint name="left_front_wheel_joint">
        <command_interface name="velocity"><param name="min">-10</param><param name="max">10</param></command_interface>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
      </joint>
      <joint name="left_rear_wheel_joint">
        <command_interface name="velocity"><param name="min">-10</param><param name="max">10</param></command_interface>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
      </joint>
      <joint name="right_front_wheel_joint">
        <command_interface name="velocity"><param name="min">-10</param><param name="max">10</param></command_interface>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
      </joint>
      <joint name="right_rear_wheel_joint">
        <command_interface name="velocity"><param name="min">-10</param><param name="max">10</param></command_interface>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
      </joint>

      <!-- Pan-tilt servos: position command + position state (order matters: 4-5) -->
      <joint name="pan_joint">
        <command_interface name="position"><param name="min">-1.57</param><param name="max">1.57</param></command_interface>
        <state_interface name="position"/>
      </joint>
      <joint name="tilt_joint">
        <command_interface name="position"><param name="min">-1.5</param><param name="max">0.87</param></command_interface>
        <state_interface name="position"/>
      </joint>
    </ros2_control>
  </xacro:if>

</robot>
